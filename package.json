{
  "name": "x-molt",
  "version": "1.0.0",
  "description": "Terminal UI for X.com account management",
  "type": "module",
  "bin": {
    "x-molt": "./dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.tsx",
    "build": "tsup",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "x",
    "twitter",
    "tui",
    "cli",
    "terminal",
    "ink",
    "x-molt"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@inkjs/ui": "^2.0.0",
    "@xenova/transformers": "^2.17.2",
    "adm-zip": "^0.5.16",
    "better-sqlite3": "^11.7.0",
    "date-fns": "^4.1.0",
    "dotenv": "^16.4.7",
    "ink": "^5.2.0",
    "react": "^18.3.1",
    "sqlite-vec": "0.1.7-alpha.2",
    "twitter-api-v2": "^1.18.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.7",
    "@types/better-sqlite3": "^7.6.12",
    "@types/react": "^18.3.18",
    "tsup": "^8.3.6",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^4.0.18"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "sharp",
      "protobufjs"
    ]
  }
}
