{
  "name": "x-molt",
  "version": "1.0.0",
  "description": "Terminal UI for X.com account management",
  "type": "module",
  "bin": {
    "x-molt": "./dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.tsx",
    "build": "tsup",
    "start": "node dist/index.js"
  },
  "keywords": ["x", "twitter", "tui", "cli", "terminal", "ink", "x-molt"],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "ink": "^5.2.0",
    "@inkjs/ui": "^2.0.0",
    "react": "^18.3.1",
    "twitter-api-v2": "^1.18.2",
    "better-sqlite3": "^11.7.0",
    "zod": "^3.24.2",
    "date-fns": "^4.1.0",
    "dotenv": "^16.4.7",
    "adm-zip": "^0.5.16"
  },
  "devDependencies": {
    "@types/react": "^18.3.18",
    "@types/better-sqlite3": "^7.6.12",
    "@types/adm-zip": "^0.5.7",
    "tsup": "^8.3.6",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  },
  "pnpm": {
